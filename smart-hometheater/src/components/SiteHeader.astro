---
import LineButton from './LineButton.astro';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  brandSubtitle?: string;
  homeHref?: string;
  navLinks?: NavLink[];
}

const {
  brandSubtitle = 'スマート ホームシアター',
  homeHref = '/',
  navLinks = [],
} = Astro.props;
---

<header class="site-header">
  <div class="container">
    <a href={homeHref} class="brand" aria-label="Smart ホームシアター ホーム">
      <img class="brand-mark" src="/images/brand/logo.png" alt="SMART HOMETHEATER ロゴ" width="28" height="28" />
      <span>
        <span class="brand-name-en">SMART HOMETHEATER</span><br />
        <span class="brand-name-jp">{brandSubtitle}</span>
      </span>
    </a>
    <nav class="nav" aria-label="メインナビ">
      {navLinks.length > 0 && (
        <ul class="nav-links">
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      )}
      <LineButton />
    </nav>
  </div>
</header>
