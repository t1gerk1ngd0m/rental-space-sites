---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LineButton from '../../components/LineButton.astro';

const navLinks = [
  { label: '写真', href: '#gallery' },
  { label: '料金', href: '#pricing' },
  { label: 'アクセス', href: '#access' },
];

const footerLinks = [
  { label: 'ブランドトップ', href: '/' },
  { label: '大船店', href: '/ofuna/' },
  { label: '料金', href: '#pricing' },
  { label: 'アクセス', href: '#access' },
  { label: 'LINEで予約', href: '#line-placeholder' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Smart ホームシアター 横浜中華街',
  image: 'https://example.com/images/motomachi/og.jpg',
  url: 'https://example.com/motomachi/',
  priceRange: '¥577〜',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '石川町1丁目',
    addressLocality: '横浜市中区',
    addressRegion: '神奈川県',
    postalCode: '231-0868',
    addressCountry: 'JP',
  },
  brand: { '@type': 'Brand', name: 'Smart ホームシアター' },
};

const heroBg = "linear-gradient(135deg, rgba(14,14,18,0.5), rgba(14,14,18,0.85)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1600&q=80')";
const introImg = "url('https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?auto=format&fit=crop&w=900&q=80')";

const galleryItems = [
  { full: 'https://images.unsplash.com/photo-1574375927938-d5a98e8ffe85?auto=format&fit=crop&w=1600&q=80', thumb: 'https://images.unsplash.com/photo-1574375927938-d5a98e8ffe85?auto=format&fit=crop&w=900&q=80', alt: 'シアタールーム全景（差し替え予定）' },
  { full: 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1600&q=80', thumb: 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=600&q=80', alt: 'スクリーン投影の様子（差し替え予定）' },
  { full: 'https://images.unsplash.com/photo-1574267432553-4b4628081c31?auto=format&fit=crop&w=1600&q=80', thumb: 'https://images.unsplash.com/photo-1574267432553-4b4628081c31?auto=format&fit=crop&w=600&q=80', alt: 'キッチンエリア（差し替え予定）' },
  { full: 'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&w=1600&q=80', thumb: 'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&w=600&q=80', alt: 'サウンドシステム（差し替え予定）' },
  { full: 'https://images.unsplash.com/photo-1585951237318-9ea5e175b891?auto=format&fit=crop&w=1600&q=80', thumb: 'https://images.unsplash.com/photo-1585951237318-9ea5e175b891?auto=format&fit=crop&w=600&q=80', alt: 'ゲーム機・周辺機器（差し替え予定）' },
];

const pricingPlans = [
  { name: '早朝プラン', price: '¥577', meta: '1時間〜利用OK', desc: '朝活・短時間の利用にぴったり。お得な早朝枠です。', featured: false, ariaLabel: 'LINEで早朝プランを予約' },
  { name: '基本プラン', price: '¥1,617', meta: '2時間〜利用OK', desc: '映画鑑賞・誕生日会など定番の利用に。一番選ばれているプランです。', featured: true, ariaLabel: 'LINEで基本プランを予約' },
  { name: 'レビュー割引プラン', price: '¥1,386', meta: '4時間〜利用OK', desc: '後日レビュー投稿にご協力いただける方向けのお得プラン。', featured: false, ariaLabel: 'LINEでレビュー割引プランを予約' },
];
---

<BaseLayout
  title="Smart ホームシアター 横浜中華街｜100インチ大画面・本格音響のレンタルスペース｜JR石川町 徒歩4分"
  description="JR石川町駅 徒歩4分、元町・中華街駅 徒歩7分。100インチスクリーン・FHDプロジェクター・4chサラウンド完備の貸切ホームシアター。映画・誕生日・ゲームに最適。最大6名、早朝¥577〜。LINE直予約OK。"
  canonical="https://example.com/motomachi/"
  ogTitle="Smart ホームシアター 横浜中華街｜100インチ大画面のレンタルスペース"
  ogDescription="JR石川町 徒歩4分。100インチ・4chサラウンドで貸切シアター体験。LINEから1分予約。"
  ogImage="https://example.com/images/motomachi/og.jpg"
  bodyClass="page-motomachi"
  brandSubtitle="横浜中華街店"
  navLinks={navLinks}
  footerLinks={footerLinks}
  copyright="© Smart ホームシアター 横浜中華街"
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero" style={`--hero-image: ${heroBg};`}>
    <div class="container">
      <p class="hero-eyebrow">MOTOMACHI · CHUKAGAI</p>
      <h1>本格音響で<br />映画視聴を、横浜中華街で。</h1>
      <p class="hero-subtitle">
        100インチスクリーン × FHDプロジェクター × 4chサラウンド。<br />
        JR石川町駅から徒歩4分。少人数で気軽に貸切できるシアタースペース。
      </p>
      <div class="hero-actions">
        <a href="#pricing" class="btn-ghost">料金を見る <span class="arrow">→</span></a>
        <LineButton size="large" label="LINEで予約する" />
      </div>
    </div>
  </section>

  <!-- SPEC BAR -->
  <section style="padding: clamp(40px, 5vw, 64px) 0; border-top: none;">
    <div class="container">
      <div class="spec-bar" aria-label="スペース基本スペック">
        <div class="spec-item">
          <div class="spec-label">スクリーン</div>
          <div class="spec-value">100<span class="small">"</span></div>
        </div>
        <div class="spec-item">
          <div class="spec-label">プロジェクター</div>
          <div class="spec-value">FHD</div>
        </div>
        <div class="spec-item">
          <div class="spec-label">音響</div>
          <div class="spec-value">4<span class="small">ch</span></div>
        </div>
        <div class="spec-item">
          <div class="spec-label">最大人数</div>
          <div class="spec-value">6<span class="small">名</span></div>
        </div>
        <div class="spec-item">
          <div class="spec-label">最寄駅</div>
          <div class="spec-value">石川町<span class="small accent"> 4分</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section>
    <div class="container">
      <div class="two-col">
        <div class="text">
          <span class="eyebrow">About this Space</span>
          <h2>横浜中華街の隠れ家、<br />本格シアター空間。</h2>
          <p>横浜の中華街エリアにある、貸切のシアター空間。100インチの大画面と4chサラウンドで、自宅では味わえない映画体験を少人数で楽しめます。</p>
          <p>FireStick・Switch・ブルーレイ・DVD完備。お手持ちの作品も、サブスクの推し作品も、大画面で。キッチン・Wi-Fiもあるので、おうちパーティーの延長として使えるのも魅力です。</p>
        </div>
        <div class="visual" style={`background-image: ${introImg};`} role="img" aria-label="横浜中華街店の室内（差し替え予定）"></div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Gallery</span>
        <h2>スペースの様子。</h2>
        <p class="mt-md">画像をタップで拡大表示できます。</p>
      </div>

      <div class="gallery">
        {galleryItems.map((item) => (
          <div
            class="gallery-item"
            data-gallery-item
            data-full={item.full}
            style={`background-image: url('${item.thumb}');`}
            aria-label={item.alt}
          ></div>
        ))}
      </div>
    </div>
  </section>

  <!-- VIDEO -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Direction</span>
        <h2>駅からの行き方。</h2>
        <p class="mt-md">JR石川町駅から徒歩4分。実際の道順を動画でご覧いただけます。</p>
      </div>

      <div class="video-wrap" data-video-embed="https://www.youtube.com/embed/dQw4w9WgXcQ">
        <div class="video-placeholder" role="button" tabindex="0" aria-label="行き方動画を再生（差し替え予定）">
          <div class="play-icon" aria-hidden="true">▶</div>
          <div>行き方動画（差し替え予定）</div>
          <small style="color: var(--text-muted); font-size: 12px;">タップで再生</small>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Pricing</span>
        <h2>料金プラン</h2>
        <p class="mt-md">人数・時間帯にあわせて選べる3プラン。表示価格は時間あたり（税込）。</p>
      </div>

      <div class="pricing-grid">
        {pricingPlans.map((plan) => (
          <div class:list={['price-card', plan.featured && 'featured']}>
            <div class="plan-name">{plan.name}</div>
            <div class="plan-price">{plan.price}<span class="unit">〜/時間</span></div>
            <div class="plan-meta">{plan.meta}</div>
            <p class="plan-desc">{plan.desc}</p>
            <LineButton label="このプランで予約" ariaLabel={plan.ariaLabel} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USAGE INFO -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Usage</span>
        <h2>ご利用案内</h2>
      </div>

      <div class="info-grid">
        <div class="info-card">
          <h3><span class="icon" aria-hidden="true">🎯</span>こんなシーンに</h3>
          <ul class="tag-list">
            <li>映画鑑賞</li>
            <li>誕生日サプライズ</li>
            <li>ゲーム大会</li>
            <li>ライブ視聴</li>
            <li>女子会</li>
            <li>少人数オフ会</li>
          </ul>
        </div>

        <div class="info-card">
          <h3><span class="icon" aria-hidden="true">📦</span>備え付け設備</h3>
          <ul class="equipment-grid">
            <li><span class="check">✓</span>100インチスクリーン</li>
            <li><span class="check">✓</span>FHDプロジェクター</li>
            <li><span class="check">✓</span>4chサラウンド</li>
            <li><span class="check">✓</span>ブルーレイ・DVD</li>
            <li><span class="check">✓</span>Amazon FireStick</li>
            <li><span class="check">✓</span>Nintendo Switch</li>
            <li><span class="check">✓</span>キッチン</li>
            <li><span class="check">✓</span>Wi-Fi</li>
          </ul>
        </div>

        <div class="info-card">
          <h3><span class="icon" aria-hidden="true">📋</span>利用にあたって</h3>
          <ul class="rule-list">
            <li class="ok"><span class="icon">●</span>飲食物のお持ち込みOK</li>
            <li class="ok"><span class="icon">●</span>少人数（〜6名）でゆったり使えます</li>
            <li><span class="icon">✕</span>喫煙はご遠慮ください</li>
            <li><span class="icon">✕</span>大声・騒音など近隣迷惑行為禁止</li>
            <li><span class="icon">✕</span>異臭の出る調理はご遠慮ください</li>
          </ul>
        </div>

        <div class="info-card">
          <h3><span class="icon" aria-hidden="true">💡</span>はじめての方へ</h3>
          <p style="font-size: 14px; color: var(--text-secondary);">入退室・鍵の受け渡しなどは、ご予約後にLINEで詳しくご案内します。手ぶらでお越しいただけます。</p>
          <p style="font-size: 13px; color: var(--text-muted); margin-top: 12px;">※ キャンセルポリシー・支払い方法も同時にご案内します。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ACCESS -->
  <section id="access" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Access</span>
        <h2>アクセス</h2>
      </div>

      <div class="access-grid">
        <div class="access-info">
          <dl>
            <dt>住所</dt>
            <dd>〒231-0868<br />神奈川県横浜市中区石川町1丁目</dd>
            <dt>最寄駅</dt>
            <dd>JR根岸線「石川町駅」 <strong>徒歩4分</strong><br />みなとみらい線「元町・中華街駅」 <strong>徒歩7分</strong></dd>
            <dt>営業時間</dt>
            <dd>10:00〜24:00（早朝プランあり）</dd>
            <dt>定休日</dt>
            <dd>不定休</dd>
          </dl>
        </div>

        <div class="map-embed">
          <iframe
            src="https://www.google.com/maps?q=神奈川県横浜市中区石川町1丁目&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="横浜中華街店の地図"
          ></iframe>
        </div>
      </div>

      <div class="cross-sell">
        <div class="text">
          <h4>もう一方の店舗もご検討ください</h4>
          <p>大人数（〜10名）・4K高画質・5ch音響なら「大船店」が便利です。</p>
        </div>
        <a href="/ofuna/" class="btn-ghost">大船店を見る <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- OPERATOR INFO -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Operator</span>
        <h2>運営情報</h2>
      </div>

      <div class="operator-table">
        <dl>
          <dt>屋号</dt>
          <dd>Smart ホームシアター 横浜中華街</dd>
          <dt>運営</dt>
          <dd>（運営者名 - 差し替え予定）</dd>
          <dt>所在地</dt>
          <dd>〒231-0868 神奈川県横浜市中区石川町1丁目</dd>
          <dt>連絡方法</dt>
          <dd>公式LINE（予約・お問い合わせ）</dd>
          <dt>支払い方法</dt>
          <dd>事前オンライン決済(差し替え予定)</dd>
          <dt>キャンセル</dt>
          <dd>ご利用日◯日前まで無料、以降は規定の料率（差し替え予定）</dd>
        </dl>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container">
      <span class="eyebrow">Booking</span>
      <h2>予約は LINE から、1分で完了。</h2>
      <p>空き状況の確認・ご予約は公式LINEから。よくあるご質問もLINEでお気軽にどうぞ。</p>
      <LineButton size="large" label="LINEで予約・空き状況確認" />
    </div>
  </section>
</BaseLayout>
