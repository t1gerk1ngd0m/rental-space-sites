---
import BaseLayout from "../layouts/BaseLayout.astro";
import LineButton from "../components/LineButton.astro";

const navLinks = [
  { label: "コンセプト", href: "#concept" },
  { label: "スペース", href: "#spaces" },
  { label: "利用シーン", href: "#scenes" },
];

const footerLinks = [
  { label: "コンセプト", href: "#concept" },
  { label: "横浜中華街店", href: "/motomachi/" },
  { label: "大船店", href: "/ofuna/" },
  { label: "LINEで予約", href: "#line-placeholder" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Smart ホームシアター",
  url: "https://example.com/",
  logo: "https://example.com/assets/logo.png",
  sameAs: [],
  subOrganization: [
    {
      "@type": "LocalBusiness",
      name: "Smart ホームシアター 横浜中華街",
      url: "https://example.com/motomachi/",
    },
    {
      "@type": "LocalBusiness",
      name: "Smart ホームシアター 大船",
      url: "https://example.com/ofuna/",
    },
  ],
};

const heroBg =
  "linear-gradient(135deg, rgba(14,14,18,0.6), rgba(14,14,18,0.85)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?auto=format&fit=crop&w=1600&q=80')";

const motomachiBg =
  "linear-gradient(180deg, rgba(14,14,18,0.2), rgba(14,14,18,0.6)), url('/images/brand/motomachi.jpg')";
const ofunaBg =
  "linear-gradient(180deg, rgba(14,14,18,0.2), rgba(14,14,18,0.6)), url('/images/brand/ofuna.png')";
---

<BaseLayout
  title="Smart ホームシアター｜100インチ大画面と本格音響のレンタルスペース（横浜中華街・大船）"
  description="Smart ホームシアターは、100インチ大画面と本格サラウンド音響を備えたレンタルスペース。横浜中華街店と大船店の2箇所。映画鑑賞・誕生日・ゲーム・ライブ視聴に。LINEから直予約で1分。"
  canonical="https://example.com/"
  ogTitle="Smart ホームシアター｜100インチ大画面のレンタルスペース"
  ogDescription="横浜中華街・大船の2箇所。本格音響と大画面で、映画・ライブ・誕生日を特別な時間に。LINEから1分予約。"
  ogImage="https://example.com/images/brand/og.jpg"
  navLinks={navLinks}
  footerLinks={footerLinks}
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero" style={`--hero-image: ${heroBg};`}>
    <div class="container">
      <p class="hero-eyebrow">PREMIUM HOME THEATER RENTAL</p>
      <h1>本格音響と<br />大画面を、あなたの街に。</h1>
      <p class="hero-subtitle">
        100インチを超える大画面、4ch以上のサラウンド音響、駅近の貸切空間。<br />
        映画もライブも、誕生日も、Smart ホームシアターで特別な時間に。
      </p>
      <div class="hero-actions">
        <a href="#spaces" class="btn-ghost">
          場所を見る <span class="arrow">→</span>
        </a>
        <LineButton size="large" label="LINEで予約する" />
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">SCROLL</div>
  </section>

  <!-- CONCEPT -->
  <section id="concept">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Concept</span>
        <h2>"自宅では味わえない"を、<br />気軽に貸切で。</h2>
        <p
          class="mt-md"
          style="max-width: 640px; margin-left: auto; margin-right: auto;"
        >
          Smart
          ホームシアターは、本物の映画館に近い体験を駅前の貸切空間で楽しめる、シアター特化のレンタルスペースです。少人数の映画鑑賞から、誕生日・ゲーム大会・ライブ配信視聴まで、用途を選びません。
        </p>
      </div>

      <div class="feature-grid">
        <div class="feature-card">
          <img
            class="feature-image"
            src="/images/brand/screen.jpg"
            alt="100インチ超の大画面シアター"
            width="2500"
            height="1663"
            loading="lazy"
          />
          <div class="feature-icon" aria-hidden="true">🎬</div>
          <h3>圧倒的な大画面</h3>
          <p>
            100インチ以上の大スクリーン。映画館のような迫力で、何を観ても忘れられない時間に。
          </p>
        </div>
        <div class="feature-card">
          <img
            class="feature-image"
            src="/images/brand/audio.jpeg"
            alt="マルチchサラウンド音響設備"
            width="447"
            height="447"
            loading="lazy"
          />
          <div class="feature-icon" aria-hidden="true">🔊</div>
          <h3>本格サラウンド音響</h3>
          <p>
            マルチchサラウンドで、音に包まれる体験。映画もライブも臨場感が段違いです。
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">🚉</div>
          <h3>駅近・アクセス良好</h3>
          <p>
            横浜中華街（石川町徒歩4分）と大船（大船駅徒歩4分）の2箇所。集合も解散もスマート。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- spaces -->
  <section id="spaces" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">spaces</span>
        <h2>スペースはこちら</h2>
        <p class="mt-md">
          少人数で気軽に楽しむなら横浜中華街店、大人数でプレミアム体験なら大船店。
        </p>
      </div>

      <div class="location-compare">
        <article class="location-card" data-location="motomachi">
          <div
            class="card-image"
            style={`background-image: ${motomachiBg};`}
            role="img"
            aria-label="横浜中華街店のイメージ"
          >
          </div>
          <span class="badge">横浜中華街</span>
          <div class="card-body">
            <div class="card-title">Smart ホームシアター 横浜中華街</div>
            <div class="card-access">
              📍 JR石川町 徒歩4分 / 元町・中華街 徒歩7分
            </div>

            <ul class="spec-list">
              <li>
                <span class="label">スクリーン</span><span class="value"
                  >100<span class="unit">インチ</span> / FHD</span
                >
              </li>
              <li>
                <span class="label">音響</span><span class="value"
                  >4ch サラウンド</span
                >
              </li>
              <li>
                <span class="label">収容</span><span class="value"
                  >最大 6<span class="unit">名</span> / 25<span class="unit"
                    >㎡</span
                  ></span
                >
              </li>
              <li>
                <span class="label">料金</span><span class="value highlight"
                  >¥1,200<span class="unit">〜 / 時間</span></span
                >
              </li>
            </ul>

            <div class="card-actions">
              <a href="/motomachi/" class="detail-btn">詳細を見る →</a>
              <LineButton label="LINE" ariaLabel="LINEで横浜中華街店を予約" />
            </div>
          </div>
        </article>

        <article class="location-card" data-location="ofuna">
          <div
            class="card-image"
            style={`background-image: ${ofunaBg};`}
            role="img"
            aria-label="大船店のイメージ"
          >
          </div>
          <span class="badge">大船</span>
          <div class="card-body">
            <div class="card-title">Smart ホームシアター 大船</div>
            <div class="card-access">📍 大船駅 南改札徒歩4分</div>

            <ul class="spec-list">
              <li>
                <span class="label">スクリーン</span><span class="value"
                  >100<span class="unit">インチ</span> / 4K UHD</span
                >
              </li>
              <li>
                <span class="label">音響</span><span class="value"
                  >5ch サラウンド</span
                >
              </li>
              <li>
                <span class="label">収容</span><span class="value"
                  >最大 10<span class="unit">名</span> / 33.2<span class="unit"
                    >㎡</span
                  ></span
                >
              </li>
              <li>
                <span class="label">料金</span><span class="value highlight"
                  >¥1,200<span class="unit">〜 / 時間</span></span
                >
              </li>
            </ul>

            <div class="card-actions">
              <a href="/ofuna/" class="detail-btn">詳細を見る →</a>
              <LineButton label="LINE" ariaLabel="LINEで大船店を予約" />
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- SCENES -->
  <section id="scenes">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Use Cases</span>
        <h2>こんなシーンにぴったり。</h2>
      </div>

      <ul
        class="tag-list"
        style="justify-content: center; max-width: 800px; margin: 0 auto;"
      >
        <li>🎬 映画鑑賞会</li>
        <li>🎮 ゲーム大会（Switch / 配信）</li>
        <li>🎤 ライブ・推し活</li>
        <li>🎂 誕生日サプライズ</li>
        <li>🍿 アニメ一気観</li>
        <li>📺 スポーツ観戦</li>
        <li>👥 女子会 / 同窓会</li>
        <li>👨‍👩‍👧 ファミリーシアター</li>
        <li>📽 上映会 / プレゼン</li>
        <li>✏️ 会議 / 研修</li>
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container">
      <span class="eyebrow">Booking</span>
      <h2>予約は LINE から1分で完了。</h2>
      <p>空き状況の確認・ご予約は、公式LINEからお気軽にどうぞ。</p>
      <LineButton size="large" label="LINEで予約・空き状況確認" />
    </div>
  </section>
</BaseLayout>
